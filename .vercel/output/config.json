{
  "version": 3,
  "overrides": {
    "index.html": {
      "path": ""
    },
    "contact/index.html": {
      "path": "contact"
    },
    "hotels/index.html": {
      "path": "hotels"
    },
    "offer/index.html": {
      "path": "offer"
    },
    "experience/index.html": {
      "path": "experience"
    },
    "hotels/golf/index.html": {
      "path": "hotels/golf"
    },
    "events/index.html": {
      "path": "events"
    },
    "casino/index.html": {
      "path": "casino"
    }
  },
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nitro"
    },
    {
      "src": "/(.*)",
      "dest": "/__nitro"
    }
  ]
}